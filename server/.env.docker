# ═══════════════════════════════════════════════════════════════════════════════
# server/.env.docker — Variables para contenedor Docker
# ═══════════════════════════════════════════════════════════════════════════════
# Este archivo se monta como docker-compose volume:
#   ./server/.env:/app/server/.env:ro
#
# Los valores con ${VAR:-default} se resuelven en docker-compose.yml
# ═══════════════════════════════════════════════════════════════════════════════

# ── Tokens y autenticación ──────────────────────────────────────────────────
JWT_SECRET=sinkia-secret-key-produccion
ADMIN_TOKEN=sinkia2026

# ── Proveedores por defecto (ollama | lmstudio | openrouter) ────────────
CLASSIFY_PROVIDER=ollama
EXTRACT_PROVIDER=ollama
DEEP_PROVIDER=ollama
CHAT_PROVIDER=ollama
HERMES_PROVIDER=ollama
OPCODE_PROVIDER=ollama
ACCOUNTING_PROVIDER=ollama
HR_PROVIDER=ollama
ANALYZER_PROVIDER=ollama
DOC_AGENT_PROVIDER=ollama

# ── Modelos por servicio (pipeline) ──────────────────────────────────────
CLASSIFY_MODEL=harmonic-hermes-9b:latest
EXTRACT_MODEL=harmonic-hermes-9b:latest
DEEP_MODEL=harmonic-hermes-9b:latest
CHAT_MODEL=harmonic-hermes-9b:latest
HERMES_MODEL=harmonic-hermes-9b:latest
OPCODE_MODEL=harmonic-hermes-9b:latest
LOCAL_LLM_MODEL=harmonic-hermes-9b:latest
LOCAL_LLM_CTX=8192
CONTEXT_SIZE=8192
NUM_CTX=8192
NUM_PREDICT=2048
TEMPERATURE=0.1

# ── Umbral de confianza ─────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6

# ── Ollama ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://sinkia-ollama:11434
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_MODEL=harmonic-hermes-9b:latest

# ── LM Studio (alternativa local) ──────────────────────────────────────
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=deepseek/deepseek-r1-0528-qwen3-8b
LMSTUDIO_PROXY_PORT=11436
LMSTUDIO_API_KEY=

# ── OpenRouter (cloud fallback) ─────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_ENABLED=true

# ── Google Gemini (API directa) ─────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-flash-latest

# ── NVIDIA NIM (opcional) ───────────────────────────────────────────────
NVIDIA_API_KEY=

# ── Cloud AI APIs (legacy, para compatibilidad) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram Bot ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MODEL=harmonic-hermes-9b:latest
ORCHESTRATOR_MODEL=harmonic-hermes-9b:latest
TELEGRAM_PROVIDER=ollama

# ── Telegram (experimental en contenedor) ───────────────────────────────
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=

# ── Revo (desactivado) ──────────────────────────────────────────────────
REVO_TOKEN_LARGO=
REVO_ADMIN_USER=
REVO_TENANT=
REVO_WEBHOOK_SECRET=
REVO_CLIENT_TOKEN=

# ── Biloop ──────────────────────────────────────────────────────────────
ASSEMPSA_BILOOP_API_KEY=
BILOOP_USER=
BILOOP_PASSWORD=
BILOOP_CIF=

# ── Portals ─────────────────────────────────────────────────────────────
# OpenClaw/Aiden (desactivado)
OPENCLAW_TOKEN=

# ── Email / SMTP (desactivado en contenedor por defecto) ────────────────
EMAIL_ACCOUNT_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=

# ── Comercio ────────────────────────────────────────────────────────────
COMMERCE_URL=http://sinkia-commerce:4400

# ── Tailscale (desactivado en contenedor) ───────────────────────────────
DISABLE_TAILSCALE_AUTH=true
TAILSCALE_ALLOW_LOCAL=true

# ── URLs internas ──────────────────────────────────────────────────────
SINKIA_API_URL=http://sinkia:3001
BACKEND_URL=http://sinkia:3001

# ── Directorios (dentro del contenedor) ─────────────────────────────────
UPLOADS_DIR=/app/uploads
DATA_DIR=/app/data

# ── Markitdown (Python) ────────────────────────────────────────────────
MARKITDOWN_EXE=/opt/markitdown-venv/bin/python
MARKITDOWN_WRAPPER=/app/server/tools/markitdown_wrapper.py