# ═══════════════════════════════════════════════════════════════════════════════
#  MATRIX DE MODELOS — Todo via Ollama (provider: ollama)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Fast Path (clasificación + extracción rápida) ─────────────────────────────
# Hermes 3 (harmonic-hermes-9b) — modelo Hermes más rápido y disponible en disco
CLASSIFY_MODEL=harmonic-hermes-9b:latest
EXTRACT_MODEL=harmonic-hermes-9b:latest

# ── Deep Path (análisis complejo, razonamiento) ───────────────────────────────
# Qwen 3.6 — solo para análisis profundo cuando el orquestador lo decide
DEEP_MODEL=qwen36-tools:latest

# ── Modelos de agentes especializados (deep path) ─────────────────────────────
# Qwen 3.6 para razonamiento complejo en legal/contabilidad/HR
ANALYZER_MODEL=qwen36-tools:latest
DOC_AGENT_MODEL=qwen36-tools:latest
ACCOUNTING_MODEL=qwen36-tools:latest
LEGAL_MODEL=qwen36-tools:latest
HR_MODEL=qwen36-tools:latest

# ── Umbral de confianza para routing ──────────────────────────────────────────
# ≥ CONFIDENCE_THRESHOLD → fast path | < → deep path
CONFIDENCE_THRESHOLD=0.6

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
# Modelo principal para chat y uso general (fast path)
OLLAMA_MODEL=harmonic-hermes-9b:latest
LOCAL_LLM_CTX=16384
AIDER_MODEL=ollama/harmonic-hermes-9b:latest

