# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (separar por comas si hay varios orígenes) ───────────────────────────
CORS_ORIGINS=https://sinkialabs.com,http://localhost:5173

# ── AI / node-llama-cpp ───────────────────────────────────────────────────────
AI_MODEL_NAME=qwen2.5-7b-instruct-q4_k_m.gguf
# 'auto' detecta Metal (Mac M4), CUDA o CPU automáticamente
AI_GPU_MODE=auto
# AI_MODEL_PATH=/ruta/absoluta/modelo.gguf   # opcional

# ── Email / Gmail IMAP ────────────────────────────────────────────────────────
EMAIL_USER=info@chickenpalace.es
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Revo POS ──────────────────────────────────────────────────────────────────
REVO_TOKEN_LARGO=tu_token_largo_de_revo
REVO_TOKEN_CORTO=tu_token_corto_de_revo

# ── Biloop ────────────────────────────────────────────────────────────────────
BILOOP_CIF=tu_cif
ASSEMPSA_BILOOP_API_KEY=tu_api_key_biloop

# ── ESEECloud ─────────────────────────────────────────────────────────────────
ESEECLOUD_USERNAME=tu_usuario
