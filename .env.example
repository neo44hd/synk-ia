# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — SynK-IA (plantilla para producción)
# ═══════════════════════════════════════════════════════════════════════════════
# Copiar a .env y rellenar los valores reales:
#   cp .env.example .env

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Ollama (LLM local) ──────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_MODEL=harmonic-hermes-9b:latest

# ── LM Studio (backup) ──────────────────────────────────────────────────────
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=
LMSTUDIO_MODEL=negentropy-claude-opus-4.7-9b

# ── OpenRouter (cloud fallback, modelos free tier) ───────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Google Gemini (API directa, opcional) ────────────────────────────────────
GOOGLE_GEMINI_API_KEY=

# ── NVIDIA NIM (opcional) ───────────────────────────────────────────────────
NVIDIA_API_KEY=

# ── Modelos por servicio (pipeline) ──────────────────────────────────────────
CLASSIFY_MODEL=harmonic-hermes-9b:latest
EXTRACT_MODEL=harmonic-hermes-9b:latest
DEEP_MODEL=harmonic-hermes-9b:latest
CHAT_MODEL=harmonic-hermes-9b:latest
HERMES_MODEL=harmonic-hermes-9b:latest
OPCODE_MODEL=harmonic-hermes-9b:latest
LOCAL_LLM_MODEL=harmonic-hermes-9b:latest
LOCAL_LLM_CTX=8192

# Proveedores por defecto (ollama | lmstudio | openrouter)
CLASSIFY_PROVIDER=ollama
EXTRACT_PROVIDER=ollama
DEEP_PROVIDER=ollama
CHAT_PROVIDER=ollama
HERMES_PROVIDER=ollama
OPCODE_PROVIDER=ollama
ACCOUNTING_PROVIDER=ollama
HR_PROVIDER=ollama
ANALYZER_PROVIDER=ollama
DOC_AGENT_PROVIDER=ollama

# ── Contexto y generación ───────────────────────────────────────────────────
NUM_CTX=8192
NUM_PREDICT=2048
TEMPERATURE=0.1

# ── Tokens y autenticación ──────────────────────────────────────────────────
JWT_SECRET=cambiar-en-produccion
ADMIN_TOKEN=sinkia2026

# ── Markitdown (Python) ─────────────────────────────────────────────────────
MARKITDOWN_EXE=/opt/markitdown-venv/bin/python
MARKITDOWN_WRAPPER=/app/server/tools/markitdown_wrapper.py

# ── Comercio (opcional) ─────────────────────────────────────────────────────
COMMERCE_URL=http://localhost:4400

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MODEL=harmonic-hermes-9b:latest
ORCHESTRATOR_MODEL=harmonic-hermes-9b:latest

# ── Email / Gmail IMAP ──────────────────────────────────────────────────────
EMAIL_ACCOUNT_ENABLED=true
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=

# ── Tailscale (acceso remoto seguro) ────────────────────────────────────────
DISABLE_TAILSCALE_AUTH=false
TAILSCALE_ALLOW_LOCAL=true

# ── URLs internas ───────────────────────────────────────────────────────────
SINKIA_API_URL=http://localhost:9301
BACKEND_URL=http://localhost:3001

# ── SynK-IA (servicio interno) ──────────────────────────────────────────────
# Configuración para el servicio SinkiaApp que consume SynK-IA como módulo
SINKIA_REPO_URL=https://github.com/neo44hd/synk-ia.git
SINKIA_LANG=js