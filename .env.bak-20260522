# =============================================================================
# ASIGNACIÓN DE MODELOS POR TAREA
# (Cada tarea usa el modelo mínimo necesario)
# =============================================================================

# Clasificación de documentos → LM Studio (con soporte tools/JSON)
# Modelo real en LM Studio: Jackrong/Negentropy-claude-opus-4.7-9B-GGUF
CLASSIFY_PROVIDER=lmstudio
CLASSIFY_MODEL=Jackrong/Negentropy-claude-opus-4.7-9B-GGUF

# Extracción de campos de documentos → Ollama (rápido, barato)
EXTRACT_MODEL=qwen2.5-coder:0.5b-instruct

# Análisis profundo de documentos → Qwen36-tools (Ollama)
DEEP_MODEL=qwen36-tools:latest

# Agente de documentos → Qwen36-tools (Ollama)
DOC_AGENT_MODEL=qwen36-tools:latest

# Agente contable → LM Studio (precisión con números)
ACCOUNTING_PROVIDER=lmstudio
ACCOUNTING_MODEL=Jackrong/Negentropy-claude-opus-4.7-9B-GGUF

# Agente legal → LM Studio (precisión jurídica)
LEGAL_PROVIDER=lmstudio
LEGAL_MODEL=Jackrong/Negentropy-claude-opus-4.7-9B-GGUF

# Agente HR / nóminas → LM Studio (precisión con datos personales)
HR_PROVIDER=lmstudio
HR_MODEL=Jackrong/Negentropy-claude-opus-4.7-9B-GGUF

# Agente analizador → Qwen36-tools (Ollama)
ANALYZER_MODEL=qwen36-tools:latest

# Chat por defecto → LM Studio (mejor calidad)
CHAT_PROVIDER=lmstudio
CHAT_MODEL=Jackrong/Negentropy-claude-opus-4.7-9B-GGUF

